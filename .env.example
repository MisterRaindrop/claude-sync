# This .env file is optional and only needed if you want claude-sync to read
# its settings from the project directory. The *recommended* way to configure
# claude-sync (especially if you run it on multiple machines) is to write
# ~/.claude-sync/config.json once per machine. `init.js` will prompt for the
# fields and create that file for you on first run.
#
# Resolution priority (highest wins):
#   1. env vars (CLAUDE_SYNC_VAULT / CLAUDE_SYNC_TOKEN / CLAUDE_SYNC_TARGET)
#   2. ~/.claude-sync/config.json
#   3. this .env file

# HTTPS form (recommended — pairs with a token, no ssh key needed):
CLAUDE_SYNC_VAULT=https://github.com/YOUR_GITHUB_USER/my-vault.git

# GitHub Personal Access Token with `repo` scope.
# Generate at: https://github.com/settings/tokens/new?scopes=repo&description=claude-sync
# CLAUDE_SYNC_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# SSH form is also supported for users with an existing ssh + gh setup:
# CLAUDE_SYNC_VAULT=git@github.com:YOUR_GITHUB_USER/my-vault.git

# Optional: override the local vault clone location (default: ~/.knowledge-vault)
# CLAUDE_SYNC_TARGET=/path/to/local/vault
