{
  "name": "claude-sync",
  "version": "1.0.0",
  "description": "MCP server that gives Claude Code a Git-synced knowledge vault and cross-machine memory",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "claude-sync": "dist/server.js",
    "claude-sync-init": "scripts/init.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/server.js scripts/*.js",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "prepare": "npm run build",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "flexsearch": "^0.7.43",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
